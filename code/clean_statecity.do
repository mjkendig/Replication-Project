		| state == "PHILADELPHIA -- ELECTRONICS" | state == "PHILADELPHIA -- GUIDED MISSILES" ///
		| state == "PHILADELPHIA CLOTHING SURVEY--HOURLY" | state == "PHILADELPHIA CLOTHING SURVEY--PIECEWORK"
