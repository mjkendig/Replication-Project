	| state == "NEW YORK- MANHATTAN" | state == "NEW YORK- NORTHPORT VA HOSP" ///
	| state == "NEW YORK- PICATINNY ARSENAL"
replace city = "NORFOLK" if state == "NORFOLK-PORTSMOTH-NEWPORT NEWS-HAMPTON"
	replace state = "VIRGINIA" if state == "NORFOLK-PORTSMOTH-NEWPORT NEWS-HAMPTON"
