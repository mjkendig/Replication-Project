gen city = substr(watitle,1,ustrpos(watitle,",")-1)
replace city = strtrim(city)
gen state = substr(watitle,ustrpos(watitle,",")+1,.)
replace state = strtrim(state) //get rid of leading/trailing blanks

replace state = "ARKANSAS" if state == "ARKANAS"
replace state = "FLORIDA" if state == "FLORDIA"
replace state = "BERMUDA" if state=="BURMUDA"
replace city = "ATLANTA" if state == "ATLANTA -- AIRCRAFT" | state == "ATLANTA -- ART-CMBT VEHICLES"
	replace state = "GEORGIA" if state == "ATLANTA -- AIRCRAFT" | state == "ATLANTA -- ART-CMBT VEHICLES"
replace city = "BOSTON" if state == "BOSTON -- AIRCRAFT" | state == "BOSTON -- SHIPBUILDING"
	replace state = "MASSACHUSETTS" if state == "BOSTON -- AIRCRAFT" | state == "BOSTON -- SHIPBUILDING"
